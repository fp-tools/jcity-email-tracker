PORT=3000
DATA_DIR=./data
DATABASE_PATH=./data/email-tracker.sqlite
CORS_ORIGIN=http://localhost:5173
APPEND_TRACKING_PARAMS=true

# Optional. If both are set, these override the saved dashboard GA4 config.
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_measurement_protocol_api_secret

# Frontend only. Leave empty when the backend serves frontend/dist.
VITE_API_BASE=
